-- Migration 18: Add session_ttl_minutes to notebook and session_version to chat_session.
-- session_ttl_minutes: how long (minutes) a /chat/ask session stays alive before
--   being auto-reset. NULL = permanent (never reset).
-- session_version: incremented on each TTL-triggered reset so the new conversation
--   uses a fresh LangGraph thread without deleting old checkpoint data.

DEFINE FIELD IF NOT EXISTS session_ttl_minutes ON TABLE notebook TYPE option<int>;
DEFINE FIELD IF NOT EXISTS session_version ON TABLE chat_session TYPE int DEFAULT 0;
